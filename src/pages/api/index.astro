---
import Layout from "../../layouts/Layout.astro"

const title = "API · Rövarspråket"
const description =
	"Ett enkelt JSON-API för att översätta till och från rövarspråket."

const base = `${Astro.site?.origin ?? Astro.url.origin}/api/v1`

const endpoints: Array<{
	method: string
	path: string
	description: string
	example: string
	response: string
	note?: string
}> = [
	{
		method: "GET",
		path: "/api/v1/to/{text}",
		description: "Översätt vanlig text till rövarspråket.",
		example: `${base}/to/${encodeURIComponent("hej")}`,
		response: `{
  "text": "hej",
  "robber": "hohejoj"
}`,
	},
	{
		method: "GET",
		path: "/api/v1/from/{robber}",
		description: "Översätt en rövarspråkssträng tillbaka till vanlig text.",
		example: `${base}/from/${encodeURIComponent("hohejoj")}`,
		response: `{
  "robber": "hohejoj",
  "text": "hej"
}`,
		note: 'Notera: eftersom "x" och "ks" båda kodas till samma rövarspråk-utdata ger avkodningen alltid tillbaka "ks". Det är en grundläggande egenskap hos rövarspråket, inte en bugg.',
	},
	{
		method: "GET",
		path: "/api/v1/validate/{robber}",
		description: "Kolla om en sträng är giltigt rövarspråk.",
		example: `${base}/validate/${encodeURIComponent("hohejoj")}`,
		response: `{
  "input": "hohejoj",
  "valid": true
}`,
	},
]

Astro.response.headers.set(
	"Cache-Control",
	"public, s-maxage=3600, stale-while-revalidate=86400",
)
---

<Layout title={title} description={description}>
	<main class="mx-auto max-w-3xl px-6 py-16">
		<p class="text-center">
			<a
				href="/"
				class="font-hand text-rovare-red hover:text-rovare-red-deep text-xl underline-offset-4 hover:underline"
			>
				← Rövarspråket
			</a>
		</p>

		<header class="mt-10 mb-12 text-center">
			<p class="font-hand text-bandit-soft text-2xl">
				– Hemlig kodbok för utvecklare –
			</p>
			<h1
				class="font-display text-bandit mt-4 text-4xl md:text-6xl"
			>
				API
			</h1>
			<p class="font-body text-bandit-soft mt-4 text-base">
				JSON-API. Svar cachas i en vecka. CORS är på.
			</p>
		</header>

		<section class="mb-12">
			<div class="parchment-card wanted-shadow px-6 py-6">
				<h2
					class="font-display text-bandit mb-4 text-2xl"
				>
					Bas-URL
				</h2>
				<code
					class="font-mono text-rovare-red block break-all text-lg"
				>
					{base}
				</code>
			</div>
		</section>

		<h2
			class="font-display text-bandit mt-12 mb-6 text-center text-3xl"
		>
			Endpoints
		</h2>
		<section class="space-y-8">
			{
				endpoints.map((endpoint) => (
					<article class="parchment-card wanted-shadow px-6 py-6">
						<div class="mb-3 flex flex-wrap items-baseline gap-3">
							<span class="font-display bg-bandit rounded-sm px-3 py-1 text-xs text-parchment tracking-wider">
								{endpoint.method}
							</span>
							<code class="font-mono text-bandit text-lg break-all">
								{endpoint.path}
							</code>
						</div>
						<p class="font-body text-bandit text-base leading-relaxed">
							{endpoint.description}
						</p>
						<p class="font-hand text-bandit-soft mt-4 text-base">
							Exempel:
						</p>
						<a
							href={endpoint.example}
							class="font-mono text-rovare-red hover:text-rovare-red-deep mt-1 block break-all text-sm underline-offset-4 hover:underline"
						>
							{endpoint.example}
						</a>
						<p class="font-hand text-bandit-soft mt-4 text-base">
							Svar:
						</p>
						<pre
							class="font-mono text-bandit border-bandit-soft/30 bg-parchment/60 mt-1 overflow-x-auto rounded-sm border p-4 text-sm"
						>{endpoint.response}</pre>
						{endpoint.note && (
							<p class="font-body text-bandit-soft mt-3 text-sm leading-relaxed">
								{endpoint.note}
							</p>
						)}
					</article>
				))
			}
		</section>

		<h2
			class="font-display text-bandit mt-16 mb-6 text-center text-3xl"
		>
			Fel
		</h2>
		<section class="parchment-card wanted-shadow px-6 py-6">
			<p class="font-body text-bandit text-base leading-relaxed">
				Fel returneras som JSON. Statuskoder:
			</p>
			<ul
				class="font-body text-bandit mt-3 list-disc space-y-1 pl-6 text-base leading-relaxed"
			>
				<li>
					<code class="font-mono">400</code> – parameter saknas (tom sträng).
				</li>
				<li>
					<code class="font-mono">422</code> – välformad indata men ogiltig
					(<code class="font-mono">/from</code> med en sträng som inte är
					rövarspråk).
				</li>
			</ul>
			<pre
				class="font-mono text-bandit border-bandit-soft/30 bg-parchment/60 mt-4 overflow-x-auto rounded-sm border p-4 text-sm"
			>{`{
  "error": {
    "status": 422,
    "message": "\\"bod\\" är inte en giltig rövarspråkssträng."
  }
}`}</pre>
		</section>

		<section class="mt-16">
			<div class="parchment-card mx-auto max-w-2xl px-6 py-6">
				<h2
					class="font-display text-bandit mb-3 text-2xl"
				>
					Vill du köra rövarspråket lokalt?
				</h2>
				<p class="font-body text-bandit text-base leading-relaxed">
					Funktionerna bakom API:t finns som ett npm-paket:{" "}
					<a
						href="https://www.npmjs.com/package/@tammergard/robber"
						class="text-rovare-red hover:text-rovare-red-deep underline-offset-4 hover:underline"
					>
						<code class="font-mono">@tammergard/robber</code>
					</a>
					. Det exponerar <code class="font-mono">toRobber</code>,
					<code class="font-mono"> fromRobber </code>
					och <code class="font-mono">pattern</code>.
				</p>
				<p
					class="font-body text-bandit-soft mt-4 text-base leading-relaxed"
				>
					Bakgrunden finns att läsa i blogginlägget{" "}
					<a
						href="https://tammergard.se/sv/blog/robber-language-generator"
						class="text-rovare-red hover:text-rovare-red-deep underline-offset-4 hover:underline"
					>
						Rövarspråksgenerator
					</a>
					.
				</p>
			</div>
		</section>

		<footer class="mt-16 text-center">
			<p class="font-hand text-bandit-soft text-base opacity-80">
				<a
					href="https://github.com/filiptammergard/robber"
					class="text-rovare-red hover:text-rovare-red-deep underline-offset-4 hover:underline"
				>
					GitHub
				</a>
				<span class="mx-2" aria-hidden="true">·</span>
				<a
					href="https://tammergard.se"
					class="text-rovare-red hover:text-rovare-red-deep underline-offset-4 hover:underline"
				>
					tammergard.se
				</a>
			</p>
		</footer>
	</main>
</Layout>
